# Gemini — required by `looptap advise`/`analyze` and by the hosted function.
GOOGLE_API_KEY=

# Modal — auth for the CLI. Grab these from https://modal.com/settings/tokens.
# If you've already run `modal token new` locally you can leave these blank and
# setup.sh will reuse the active profile.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Modal workspace (username or org slug). Used to build the deployment URL:
#   https://<MODAL_WORKSPACE>--<app>-<function>.modal.run
# If blank, setup.sh resolves it from `modal profile current`.
MODAL_WORKSPACE=

# Deployment knobs — override the declarations in deploy/app.py.
LOOPTAP_MODAL_APP=looptap
LOOPTAP_MODAL_FUNCTION=web
LOOPTAP_MODAL_SECRET=looptap-secrets

# Modal proxy auth tokens — required by every client hitting the deployed URL.
# Create a pair at https://modal.com/settings/proxy-auth-tokens. If these are
# set, scripts/deploy.sh will use them to smoke-test /healthz end-to-end.
MODAL_PROXY_TOKEN_ID=
MODAL_PROXY_TOKEN_SECRET=
