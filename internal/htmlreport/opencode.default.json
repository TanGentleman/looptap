{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "deny",
      "git symbolic-ref *": "allow",
      "git rev-parse *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git ls-files *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git -c *": "deny",
      "git config *": "deny",
      "git submodule *": "deny",
      "git fetch *": "deny",
      "git push *": "deny",
      "git clone *": "deny"
    },
    "edit": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  }
}
